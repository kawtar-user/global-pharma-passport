ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/global_pharma_passport
JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ISSUER=global-pharma-passport-api
JWT_AUDIENCE=global-pharma-passport-clients
APP_BASE_URL=http://localhost:3000
REQUIRE_VERIFIED_EMAIL_FOR_PRODUCT=false
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1
FORCE_HTTPS=false
DOCS_ENABLED=true
DEFAULT_LANGUAGE=fr
DEFAULT_COUNTRY=MA
ENABLE_PRODUCT_ANALYTICS=true
LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
